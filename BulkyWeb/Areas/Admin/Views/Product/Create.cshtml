@model Product

<div class="container-fluid py-4 mb-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-11">
            <div class="card shadow-sm" style="min-height: 600px;">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Create New Product</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row">
                            <!-- Left Column - Main Information -->
                            <div class="col-md-8">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Title" class="form-label fw-bold"></label>
                                            <input asp-for="Title" class="form-control" placeholder="Enter Product name" aria-describedby="TitleValidation" />
                                            <span asp-validation-for="Title" class="text-danger" id="TitleValidation"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="ISBN" class="form-label fw-bold"></label>
                                            <input asp-for="ISBN" class="form-control" placeholder="Enter ISBN" aria-describedby="ISBNValidation" />
                                            <span asp-validation-for="ISBN" class="text-danger" id="ISBNValidation"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Author" class="form-label fw-bold"></label>
                                            <input asp-for="Author" class="form-control" placeholder="Enter Author Name" aria-describedby="AuthorValidation" />
                                            <span asp-validation-for="Author" class="text-danger" id="AuthorValidation"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <!-- Category Dropdown (Disabled) -->
                                        <div class="mb-3">
                                            <label for="CategoryId" class="form-label fw-bold text-muted">Category</label>
                                            <select id="CategoryId" class="form-select" disabled>
                                                <option>Category selection coming soon</option>
                                                <!-- To enable: Populate options dynamically from controller -->
                                            </select>
                                            <small class="text-muted fst-italic">Category selection will be enabled in future updates</small>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label fw-bold"></label>
                                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter Description" aria-describedby="DescriptionValidation"></textarea>
                                    <span asp-validation-for="Description" class="text-danger" id="DescriptionValidation"></span>
                                </div>
                            </div>

                            <!-- Right Column - Pricing and Image -->
                            <div class="col-md-4">
                                <!-- Image Upload (Disabled) -->
                                <div class="mb-3 text-center border rounded p-3 bg-light">
                                    <label for="ImageUpload" class="form-label fw-bold text-muted">Product Image</label>
                                    <div class="mb-2">
                                        <img src="/images/placeholder.png" style="max-height: 150px; max-width: 100%;" alt="Product Image" class="img-thumbnail mx-auto d-block" />
                                    </div>
                                    <div class="input-group">
                                        <input type="file" id="ImageUpload" class="form-control" accept="image/*" disabled />
                                        <!-- To enable: Add asp-for and validation -->
                                    </div>
                                    <small class="text-muted fst-italic">Image upload will be enabled in future updates</small>
                                </div>

                                <!-- Pricing Section -->
                                <div class="card mt-3">
                                    <div class="card-header bg-light">
                                        <h6 class="mb-0">Pricing</h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-6">
                                                <div class="mb-2">
                                                    <label asp-for="ListPrice" class="form-label fw-bold small"></label>
                                                    <div class="input-group input-group-sm">
                                                        <span class="input-group-text">$</span>
                                                        <input asp-for="ListPrice" type="number" step="0.01" class="form-control" placeholder="List Price" aria-describedby="ListPriceValidation" />
                                                    </div>
                                                    <span asp-validation-for="ListPrice" class="text-danger small" id="ListPriceValidation"></span>
                                                </div>
                                            </div>
                                            <div class="col-6">
                                                <div class="mb-2">
                                                    <label asp-for="Price" class="form-label fw-bold small"></label>
                                                    <div class="input-group input-group-sm">
                                                        <span class="input-group-text">$</span>
                                                        <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Price 1-50" aria-describedby="PriceValidation" />
                                                    </div>
                                                    <span asp-validation-for="Price" class="text-danger small" id="PriceValidation"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-6">
                                                <div class="mb-2">
                                                    <label asp-for="Price50" class="form-label fw-bold small"></label>
                                                    <div class="input-group input-group-sm">
                                                        <span class="input-group-text">$</span>
                                                        <input asp-for="Price50" type="number" step="0.01" class="form-control" placeholder="Price 50+" aria-describedby="Price50Validation" />
                                                    </div>
                                                    <span asp-validation-for="Price50" class="text-danger small" id="Price50Validation"></span>
                                                </div>
                                            </div>
                                            <div class="col-6">
                                                <div class="mb-2">
                                                    <label asp-for="Price100" class="form-label fw-bold small"></label>
                                                    <div class="input-group input-group-sm">
                                                        <span class="input-group-text">$</span>
                                                        <input asp-for="Price100" type="number" step="0.01" class="form-control" placeholder="Price 100+" aria-describedby="Price100Validation" />
                                                    </div>
                                                    <span asp-validation-for="Price100" class="text-danger small" id="Price100Validation"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 d-flex justify-content-between">
                            <div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-save"></i> Create
                                </button>
                            </div>
                            <div>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="bi bi-arrow-left"></i> Back to List
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}